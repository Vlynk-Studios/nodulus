{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@middleware/*": ["./src/middleware/*"],
      "@middleware/*.js": ["./src/middleware/*.ts"],
      "@config/*": ["./src/config/*"],
      "@config/*.js": ["./src/config/*.ts"],
      "@modules/*": ["./src/modules/*"],
      "@modules/*.js": ["./src/modules/*.ts"]
    }
  },
  "include": ["src/**/*"]
}

